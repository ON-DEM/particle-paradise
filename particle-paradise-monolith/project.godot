;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Particle Paradise"
run/main_scene="uid://bqtdb08c10vgr"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.1254902, 0.12941177, 0.14117648, 1)
boot_splash/stretch_mode=0
boot_splash/image="uid://dbdc56rwfxwpi"
config/icon="res://icon.svg"

[autoload]

TweenFX="*uid://d2n10rw2dnx8o"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/TweenFX/plugin.cfg")

