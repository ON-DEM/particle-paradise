[node name="Label" type="Label" parent="CanvasLayer/NextLevel/CenterContainer" unique_id=35774064]
layout_mode = 2
size_flags_vertical = 3
theme_override_fonts/font = ExtResource("7_f3epd")
theme_override_font_sizes/font_size = 48
text = "NICE!

YOU JUST EXPERIENCED THE INFLUENCE OF MASS ON MOMENTUM!

IF THE TWO PARTICLES ARE MADE OUT OF THE SAME MATERIAL THEN THEIR
 SIZE WILL DEPEND ON THEIR MASS.

WHEN THE TWO PARTICLES HIT EACH OTHER, MOMENTUM IS TRANSFERRED
FROM ONE TO THE OTHER, DEPENDENT ON THEIR VELOCITIES AND MASS.

AFTER THE COLLISION, THE MOMENTUM OF THE TWO PARTICLES HAS TO BE
EQUAL, WHICH IS WHY A BIGGER PARTICLE IS SLOWER THAN A
SMALLER PARTICLE."
horizontal_alignment = 1
vertical_alignment = 1

